#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BACKEND_DIR="$ROOT_DIR/backend"
VENV_DIR="$BACKEND_DIR/.venv"
ENV_FILE="$BACKEND_DIR/.env"

usage() {
  cat <<'USAGE'
Usage: ./scripts/backend {env|install|run|test|lint|status|reset} [env]

  env      Re-create backend/.env (copy from .env.<env>.example for dev,
           or validate and write required env vars for non-dev)
  install  Clean-install venv and deps (no env changes)
  run      Run FastAPI dev server with uvicorn using selected env
  test     Run backend pytest suite
  lint     Run backend ruff checks
  status   Show backend env, venv, app, and test status
  reset    Delete backend venv and local backend/.env

Examples:
  ./scripts/backend env dev
  ./scripts/backend install
  ./scripts/backend env prod
  ./scripts/backend install
  ./scripts/backend run dev
USAGE
}

ENV_NAME="${2:-dev}"

validate_env_name() {
  if [ -z "$ENV_NAME" ]; then
    echo "Backend environment cannot be empty." >&2
    exit 1
  fi
}

env_example_file() {
  echo "$BACKEND_DIR/.env.$ENV_NAME.example"
}

is_dev_env() {
  [ "$ENV_NAME" = "dev" ]
}

python_bin() {
  if command -v python3.12 >/dev/null 2>&1; then
    echo "python3.12"
  elif command -v python3 >/dev/null 2>&1; then
    echo "python3"
  else
    echo "Python 3.12 or python3 is required." >&2
    exit 1
  fi
}

_required_env_vars() {
  if is_dev_env; then
    return 0
  fi

  for var in \
    AUTH_ISSUER AUTH_JWKS_URL AUTH_AUDIENCE \
    DYNAMODB_TABLE_NAME \
    AWS_DEFAULT_REGION AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY
  do
    if [ -z "${!var:-}" ]; then
      echo "Missing required environment variable for $ENV_NAME: $var" >&2
      exit 1
    fi
  done
}

setup_env() {
  validate_env_name

  rm -f "$ENV_FILE"
  echo "Removed backend/.env."

  if is_dev_env; then
    local template
    template="$(env_example_file)"
    if [ ! -f "$template" ]; then
      echo "Missing $template." >&2
      exit 1
    fi
    cp "$template" "$ENV_FILE"
    echo "Created backend/.env from $template."
  else
    _required_env_vars

    {
      echo "# Auto-generated by scripts/backend for env: $ENV_NAME"
      echo "APP_ENV=$ENV_NAME"
      echo ""
      echo "# Auth"
      echo "AUTH_ISSUER=$AUTH_ISSUER"
      echo "AUTH_JWKS_URL=$AUTH_JWKS_URL"
      echo "AUTH_AUDIENCE=$AUTH_AUDIENCE"
      echo ""
      echo "# DynamoDB"
      echo "DYNAMODB_TABLE_NAME=$DYNAMODB_TABLE_NAME"
      echo "DYNAMODB_REGION=${DYNAMODB_REGION:-ap-southeast-1}"
      echo ""
      echo "# AWS"
      echo "AWS_DEFAULT_REGION=$AWS_DEFAULT_REGION"
      echo "AWS_ACCESS_KEY_ID=$AWS_ACCESS_KEY_ID"
      echo "AWS_SECRET_ACCESS_KEY=$AWS_SECRET_ACCESS_KEY"
    } > "$ENV_FILE" || { echo "Failed to write $ENV_FILE" >&2; exit 1; }

    echo "Created backend/.env for $ENV_NAME from environment variables."
  fi
}

ensure_venv() {
  if [ ! -d "$VENV_DIR" ]; then
    create_venv
  fi
}

create_venv() {
  local py
  py="$(python_bin)"
  "$py" -m venv "$VENV_DIR"
  echo "Created backend/.venv using $py."
}

clean_install() {
  rm -rf "$VENV_DIR"
  create_venv
  "$VENV_DIR/bin/python" -m pip install --upgrade pip
  "$VENV_DIR/bin/pip" install -e "$BACKEND_DIR[dev]"
}

require_app() {
  if [ ! -f "$BACKEND_DIR/app/main.py" ]; then
    echo "Backend app is not implemented yet: missing backend/app/main.py." >&2
    exit 1
  fi
}

require_tests() {
  if [ ! -d "$BACKEND_DIR/tests" ]; then
    echo "Backend tests are not implemented yet: missing backend/tests/." >&2
    exit 1
  fi
}

if [ $# -lt 1 ] || [ $# -gt 2 ]; then
  usage
  exit 1
fi

case "$1" in
  env)
    setup_env
    ;;
  install)
    clean_install
    ;;
  run)
    require_app
    ensure_venv
    cd "$BACKEND_DIR"
    "$VENV_DIR/bin/uvicorn" app.main:app --reload
    ;;
  test)
    require_tests
    ensure_venv
    cd "$BACKEND_DIR"
    "$VENV_DIR/bin/pytest"
    ;;
  lint)
    require_app
    ensure_venv
    cd "$BACKEND_DIR"
    if [ -d "$BACKEND_DIR/tests" ]; then
      "$VENV_DIR/bin/ruff" check app tests
    else
      "$VENV_DIR/bin/ruff" check app
    fi
    ;;
  status)
    echo "Backend directory: $BACKEND_DIR"
    if [ -f "$ENV_FILE" ]; then
      echo "Env file: present"
      grep -E '^(APP_ENV|AUTH_ISSUER|AUTH_AUDIENCE|DYNAMODB_TABLE_NAME)=' "$ENV_FILE" || true
    else
      echo "Env file: missing"
    fi

    if [ -d "$VENV_DIR" ]; then
      echo "Virtualenv: present"
      "$VENV_DIR/bin/python" --version
    else
      echo "Virtualenv: missing"
    fi

    [ -f "$BACKEND_DIR/app/main.py" ] && echo "App: present" || echo "App: missing"
    [ -d "$BACKEND_DIR/tests" ] && echo "Tests: present" || echo "Tests: missing"
    ;;
  reset)
    rm -rf "$VENV_DIR" "$ENV_FILE"
    echo "Deleted backend/.venv and backend/.env."
    ;;
  *)
    usage
    exit 1
    ;;
esac
