# Copy to helper/docker/.env and replace values with real dev app credentials.
# Do not commit helper/docker/.env.

KEYCLOAK_GOOGLE_CLIENT_ID=replace-with-google-client-id
KEYCLOAK_GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

KEYCLOAK_FACEBOOK_CLIENT_ID=replace-with-facebook-client-id
KEYCLOAK_FACEBOOK_CLIENT_SECRET=replace-with-facebook-client-secret
